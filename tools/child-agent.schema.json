{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/agent-config.schema.json",
  "title": "Realtime Agent Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "role",
    "voice_and_language",
    "scope",
    "hard_rules",
    "conversation_states",
    "escalation_rules",
    "closing"
  ],
  "properties": {
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_name",
        "description"
      ],
      "properties": {
        "agent_name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "voice_and_language": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "voice_style"
      ],
      "properties": {
        "voice_style": {
          "type": "string",
          "minLength": 1
        },
        "language_variant": {
          "type": "string"
        },
        "vocabulary_rules": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "allowed_topics"
      ],
      "properties": {
        "allowed_topics": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "out_of_scope": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "response": { "type": "string" },
            "if_customer_persists": { "type": "string" }
          }
        },
        "out_of_scope_response": {
          "type": "string"
        }
      }
    },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "session_context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "start_of_call": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "say": { "type": "string" },
            "initial_tool_call": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "tool_name": { "type": "string" },
                "input": {}
              }
            },
            "holding_line_if_needed": { "type": "string" },
            "then_ask": { "type": "string" }
          }
        },
        "say": {
          "type": "string"
        },
        "initial_tool_name": {
          "type": "string"
        },
        "initial_tool_input": {},
        "then_ask": {
          "type": "string"
        },
        "stored_fields_if_context_returned": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tool_usage_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conversation_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/conversationState"
      }
    },
    "escalation_rules": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "escalate_immediately_if": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "say": {
          "type": "string"
        }
      }
    },
    "closing": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "if_task_completes_successfully": { "type": "string" },
        "if_flow_ends_without_resolution": { "type": "string" },
        "success": { "type": "string" },
        "unresolved": { "type": "string" }
      }
    }
  },
  "$defs": {
    "branch": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "condition",
        "action"
      ],
      "properties": {
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "next_state": {
          "type": "string"
        }
      }
    },
    "conversationState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "goal"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "when_to_use": {
          "type": "string"
        },
        "instructions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "say": {
          "type": "string"
        },
        "next_state": {
          "type": "string"
        },
        "default_next_state": {
          "type": "string"
        },
        "branches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/branch"
          }
        },
        "tool_usage": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "tool_name": { "type": "string" },
            "call_tool_only_when": { "type": "string" },
            "do_not_call_tool_if": { "type": "string" },
            "trigger": { "type": "string" },
            "blocker": { "type": "string" }
          }
        },
        "tool_outcomes": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "if_success": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "say": { "type": "string" }
              }
            },
            "if_failure": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "behaviour": { "type": "string" },
                "next_state": { "type": "string" }
              }
            }
          }
        },
        "entry_rule": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "only_enter_if": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}