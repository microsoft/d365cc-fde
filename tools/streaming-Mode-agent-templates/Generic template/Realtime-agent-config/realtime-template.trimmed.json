      ],
      "branches": [
        {
          "condition": "[CONDITION_A]",
          "action": "[ACTION_A]",
          "next_state": "[NEXT_STATE_A]"
        },
        {
          "condition": "[CONDITION_B]",
          "action": "[ACTION_B]",
          "next_state": "[NEXT_STATE_B]"
        }
      ]
    }
  ],
  "escalation_rules": {
    "conditions": [
      "[ESCALATION_REASON_1]",
      "[ESCALATION_REASON_2]"
    ],
    "say": "[ESCALATION_MESSAGE]"
