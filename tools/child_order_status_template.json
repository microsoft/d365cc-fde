{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/microsoft/d365cc-fde/agent-templates/realtime-agent.schema.json",
  "title": "D365 Contact Center Real-time Agent Template",
  "description": "Schema for validating real-time voice agent configuration templates",
  "type": "object",
  "required": ["role", "persona", "objective"],
  "properties": {
    "role": {
      "type": "string",
      "const": "system",
      "description": "Must be 'system' for agent templates"
    },
    "persona": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Agent persona and voice characteristics"
        }
      }
    },
    "objective": {
      "type": "string",
      "description": "Primary goal of the agent"
    },
    "scope_guardrails": {
      "type": "object",
      "properties": {
        "allowed_topics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "out_of_scope_behavior": {
          "type": "string"
        }
      }
    },
    "greeting_rules": {
      "type": "object",
      "properties": {
        "priority": { "type": "string" },
        "greeting_script": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "intent_confidence_model": {
      "type": "object",
      "properties": {
        "high_confidence": { "type": "string" },
        "medium_confidence": { "type": "string" },
        "low_confidence": { "type": "string" }
      }
    },
    "intent_handling": {
      "type": "object",
      "properties": {
        "high_confidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "medium_confidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "low_confidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "absolute_rules": {
      "type": "object",
      "properties": {
        "priority": { "type": "string" },
        "do": {
          "type": "array",
          "items": { "type": "string" }
        },
        "do_not": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "voice_and_tone": {
      "type": "object",
      "properties": {
        "attributes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "delivery": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tool_usage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "usage": { "type": "string" },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "behavior": {
            "type": "array",
            "items": { "type": "string" }
          },
          "output_handling": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "fallback_and_escalation": {
      "type": "object",
      "properties": {
        "invalid_input": { "type": "string" },
        "unresolvable": { "type": "string" }
      }
    },
    "analytics": {
      "type": "object",
      "properties": {
        "business": {
          "type": "array",
          "items": { "type": "string" }
        },
        "telemetry": {
          "type": "array",
          "items": { "type": "string" }
        },
        "health": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
